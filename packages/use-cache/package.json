{
  "name": "@rari/use-cache",
  "type": "module",
  "version": "0.15.0",
  "description": "Native 'use cache' directive transform addon for rari",
  "author": "Ryan Skinner",
  "license": "MIT",
  "homepage": "https://github.com/rari-build/rari#readme",
  "repository": {
    "directory": "packages/use-cache",
    "type": "git",
    "url": "git+https://github.com/rari-build/rari.git"
  },
  "bugs": {
    "url": "https://github.com/rari-build/rari/issues"
  },
  "keywords": [
    "rari",
    "use-cache",
    "transform",
    "napi",
    "napi-rs",
    "rust",
    "react",
    "server-components"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./runtime/cache-wrapper": {
      "types": "./dist/runtime/cache-wrapper.d.mts",
      "import": "./dist/runtime/cache-wrapper.mjs",
      "default": "./dist/runtime/cache-wrapper.mjs"
    },
    "./runtime/cache-dynamic-context": {
      "types": "./dist/runtime/cache-dynamic-context.d.mts",
      "import": "./dist/runtime/cache-dynamic-context.mjs",
      "default": "./dist/runtime/cache-dynamic-context.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build": "pnpm typecheck && vp pack",
    "clean": "node --eval \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc"
  },
  "peerDependencies": {
    "react-server-dom-webpack": "catalog:react"
  },
  "optionalDependencies": {
    "@rari/use-cache-darwin-arm64": "0.15.0",
    "@rari/use-cache-darwin-x64": "0.15.0",
    "@rari/use-cache-linux-arm64": "0.15.0",
    "@rari/use-cache-linux-x64": "0.15.0",
    "@rari/use-cache-win32-arm64": "0.15.0",
    "@rari/use-cache-win32-x64": "0.15.0"
  },
  "devDependencies": {
    "@types/node": "catalog:typescript",
    "typescript": "catalog:typescript",
    "typescript-7": "catalog:typescript",
    "vite-plus": "catalog:build"
  }
}
