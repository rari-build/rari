{
  "name": "rari",
  "type": "module",
  "version": "0.15.4",
  "description": "Runtime Accelerated Rendering Infrastructure (rari)",
  "author": "Ryan Skinner",
  "license": "MIT",
  "homepage": "https://github.com/rari-build/rari#readme",
  "repository": {
    "directory": "packages/rari",
    "type": "git",
    "url": "git+https://github.com/rari-build/rari.git"
  },
  "bugs": {
    "url": "https://github.com/rari-build/rari/issues"
  },
  "keywords": [
    "react",
    "server-components",
    "rsc",
    "rust",
    "vite",
    "framework",
    "performance",
    "ssr",
    "typescript",
    "deno",
    "v8",
    "streaming",
    "fast",
    "zero-config",
    "full-stack",
    "web-framework"
  ],
  "sideEffects": [
    "./dist/runtime/entry-client.mjs",
    "./dist/runtime/rsc-client-runtime.mjs"
  ],
  "exports": {
    ".": {
      "node": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./image": {
      "types": "./dist/image.d.mts",
      "default": "./dist/image.mjs"
    },
    "./mdx": {
      "types": "./dist/mdx.d.mts",
      "default": "./dist/mdx.mjs"
    },
    "./mdx/define": {
      "types": "./dist/mdx/define.d.mts",
      "default": "./dist/mdx/define.mjs"
    },
    "./mdx/registry": {
      "types": "./dist/mdx/registry.d.mts",
      "default": "./dist/mdx/registry.mjs"
    },
    "./og": {
      "types": "./dist/og.d.mts",
      "default": "./dist/og.mjs"
    },
    "./package.json": "./package.json",
    "./router": {
      "types": "./dist/router.d.mts",
      "default": "./dist/router.mjs"
    },
    "./headers": {
      "types": "./dist/headers.d.mts",
      "default": "./dist/headers.mjs"
    },
    "./runtime/call-server": {
      "types": "./dist/runtime/call-server.d.mts",
      "default": "./dist/runtime/call-server.mjs"
    },
    "./runtime/action-flight-refresh": {
      "types": "./dist/runtime/action-flight-refresh.d.mts",
      "default": "./dist/runtime/action-flight-refresh.mjs"
    },
    "./runtime/merge-flight-refresh": {
      "types": "./dist/runtime/merge-flight-refresh.d.mts",
      "default": "./dist/runtime/merge-flight-refresh.mjs"
    },
    "./runtime/flight-route-cache": {
      "types": "./dist/runtime/flight-route-cache.d.mts",
      "default": "./dist/runtime/flight-route-cache.mjs"
    },
    "./runtime/flight-router-state": {
      "types": "./dist/runtime/flight-router-state.d.mts",
      "default": "./dist/runtime/flight-router-state.mjs"
    },
    "./runtime/action-revalidation-kind": {
      "types": "./dist/runtime/action-revalidation-kind.d.mts",
      "default": "./dist/runtime/action-revalidation-kind.mjs"
    },
    "./runtime/entry-client": {
      "types": "./dist/runtime/entry-client.d.mts",
      "default": "./dist/runtime/entry-client.mjs"
    },
    "./runtime/rsc-references": {
      "types": "./dist/runtime/rsc-references.d.mts",
      "default": "./dist/runtime/rsc-references.mjs"
    },
    "./runtime/rsc-client-runtime": {
      "types": "./dist/runtime/rsc-client-runtime.d.mts",
      "default": "./dist/runtime/rsc-client-runtime.mjs"
    },
    "./runtime/ErrorBoundaryWrapper": {
      "types": "./dist/runtime/ErrorBoundaryWrapper.d.mts",
      "default": "./dist/runtime/ErrorBoundaryWrapper.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    },
    "./*.mjs": "./dist/*.mjs"
  },
  "types": "dist/index.d.mts",
  "bin": {
    "rari": "./dist/cli.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build": "pnpm typecheck && vp pack",
    "clean": "node --eval \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "catalog:mdx",
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "peerDependenciesMeta": {
    "@mdx-js/mdx": {
      "optional": true
    }
  },
  "dependencies": {
    "lightningcss": "catalog:build",
    "react-server-dom-webpack": "catalog:react",
    "rolldown": "catalog:build"
  },
  "optionalDependencies": {
    "@rari/use-cache": "0.15.4",
    "rari-darwin-arm64": "0.15.4",
    "rari-darwin-x64": "0.15.4",
    "rari-linux-arm64": "0.15.4",
    "rari-linux-x64": "0.15.4",
    "rari-win32-arm64": "0.15.4",
    "rari-win32-x64": "0.15.4"
  },
  "devDependencies": {
    "@mdx-js/mdx": "catalog:mdx",
    "@rari/deploy": "workspace:*",
    "@rari/logger": "workspace:*",
    "@types/node": "catalog:typescript",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "typescript": "catalog:typescript",
    "typescript-7": "catalog:typescript",
    "vite-plus": "catalog:build"
  }
}
