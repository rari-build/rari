{
  "name": "create-rari-app",
  "type": "module",
  "version": "0.5.17",
  "description": "Create Runtime Accelerated Rendering Infrastructure (rari) applications with no build configuration",
  "author": "Ryan Skinner",
  "license": "MIT",
  "homepage": "https://github.com/rari-build/rari#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rari-build/rari.git",
    "directory": "packages/create-rari-app"
  },
  "bugs": {
    "url": "https://github.com/rari-build/rari/issues"
  },
  "keywords": [
    "rari",
    "react",
    "scaffolding",
    "cli",
    "create-app",
    "generator",
    "boilerplate",
    "template",
    "server-components",
    "rust",
    "framework",
    "zero-config",
    "starter",
    "project-template"
  ],
  "bin": {
    "create-rari-app": "dist/index.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "pnpm typecheck && vp pack",
    "dev": "vp pack --watch",
    "clean": "node --eval \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@clack/prompts": "catalog:cli"
  },
  "devDependencies": {
    "@types/node": "catalog:typescript",
    "typescript": "catalog:typescript",
    "typescript-7": "catalog:typescript",
    "vite-plus": "catalog:build"
  }
}
