{
  "name": "@rari/web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "description": "Runtime Accelerated Rendering Infrastructure (rari) Website",
  "author": "Ryan Skinner",
  "license": "MIT",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "rari build",
