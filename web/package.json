    "@shikijs/langs": "catalog:mdx",
    "@shikijs/themes": "catalog:mdx",
    "@shikijs/types": "catalog:mdx",
    "mermaid": "catalog:mdx",
    "posthog-js": "catalog:analytics",
    "rari": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "remark-gfm": "catalog:mdx"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:tailwind",
    "@types/node": "catalog:typescript",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:typescript",
    "tailwindcss": "catalog:tailwind",
    "vite-plus": "catalog:build"
  }
