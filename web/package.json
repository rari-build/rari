    "lint:fix": "vp lint --fix",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@mdx-js/mdx": "catalog:mdx",
    "@sentry/react": "catalog:monitoring",
    "@shikijs/core": "catalog:mdx",
