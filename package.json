{
  "name": "@rari/monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "lint": "pnpm -r run lint && vp lint crates/ && eslint crates/ packages/ web/ examples/ test/",
    "lint:fix": "pnpm -r run lint:fix && vp lint crates/ --fix && eslint crates/ packages/ web/ examples/ test/ --fix",
    "lint:knip": "knip",
    "test:unit": "vp test",
    "test:unit:run": "vp test run",
    "test:unit:coverage": "vp test run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test smoke.spec.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:eslint",
    "@eslint-react/eslint-plugin": "catalog:eslint",
    "@playwright/test": "catalog:testing",
    "@types/node": "catalog:typescript",
    "@typescript-eslint/utils": "catalog:eslint",
    "@typescript/native-preview": "catalog:typescript",
    "@vitest/coverage-v8": "catalog:testing",
    "eslint": "catalog:eslint",
    "eslint-plugin-de-morgan": "catalog:eslint",
    "eslint-plugin-oxlint": "catalog:eslint",
    "eslint-plugin-react-hooks": "catalog:eslint",
    "eslint-plugin-react-refresh": "catalog:eslint",
    "knip": "catalog:eslint",
    "vite-plus": "catalog:build"
  }
}
